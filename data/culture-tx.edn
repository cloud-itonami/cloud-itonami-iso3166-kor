#:culture{:id "kor.dish.kimchi", :name "Kimchi", :country "KOR", :kind :dish, :summary "Traditional Korean side dish of salted and fermented vegetables, a staple eaten with almost every Korean meal; South Korea's kimjang (making and sharing kimchi) was inscribed by UNESCO in 2013.", :url "https://en.wikipedia.org/wiki/Kimchi", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kor.dish.bibimbap", :name "Bibimbap", :country "KOR", :kind :dish, :summary "Korean rice dish of warm white rice topped with namul (seasoned vegetables) and gochujang; South Korean cities such as Jeonju, Jinju and Tongyeong are known for their versions.", :url "https://en.wikipedia.org/wiki/Bibimbap", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kor.dish.bulgogi", :name "Bulgogi", :country "KOR", :kind :dish, :summary "Korean dish of thin, marinated slices of beef grilled or pan-cooked, very popular in South Korea from upscale restaurants to supermarket pan-ready kits.", :url "https://en.wikipedia.org/wiki/Bulgogi", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kor.dish.tteokbokki", :name "Tteokbokki", :country "KOR", :kind :dish, :summary "Korean food made from small garae-tteok rice cakes, well known as Korea's representative street food.", :url "https://en.wikipedia.org/wiki/Tteokbokki", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kor.beverage.soju", :name "Soju", :country "KOR", :kind :beverage, :summary "Clear, colorless distilled alcoholic beverage from Korea, traditionally made from rice; it originated in 13th-century Goryeo and remains deeply embedded in South Korean culture.", :url "https://en.wikipedia.org/wiki/Soju", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "kor.beverage.makgeolli", :name "Makgeolli", :country "KOR", :kind :beverage, :summary "Milky, lightly sparkling Korean rice wine; it was the most-consumed alcoholic drink in South Korea in the 1960s and 1970s and has seen a recent resurgence.", :url "https://en.wikipedia.org/wiki/Makgeolli", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:url "https://en.wikipedia.org/wiki/Korean_paper", :id "kor.craft.hanji", :kind :craft, :name-local "한지", :country "KOR", :retrieved-at "2026-07-17", :summary "Traditional handmade paper from Korea, made from the inner bark of the paper mulberry, a tree native to Korea.", :name "Hanji", :url-provenance :wikipedia-en}
#:culture{:id "kor.festival.chuseok", :name "Chuseok", :country "KOR", :kind :festival, :summary "Major Korean mid-autumn harvest festival on the 15th day of the 8th lunisolar month; a three-day national holiday in South Korea when people travel to ancestral hometowns.", :url "https://en.wikipedia.org/wiki/Chuseok", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
